<?xml version="1.0" encoding="utf-8"?>
<!--
  YT Archiver launcher foreground: a bold "download / save" mark (arrow into a
  tray) in white, drawn within the adaptive-icon safe zone (central ~66dp of the
  108dp canvas). Also used as the monochrome (themed-icon) layer.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Arrow stem (rounded top) -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M49,31 a3,3 0 0 1 3,-3 h4 a3,3 0 0 1 3,3 v21 h-10 z" />

    <!-- Arrow head pointing down -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M38,50 h32 l-16,22 z" />

    <!-- Tray / baseline -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M41,78 h26 a3,3 0 0 1 0,6 h-26 a3,3 0 0 1 0,-6 z" />
</vector>
